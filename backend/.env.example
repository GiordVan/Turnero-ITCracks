DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="your-super-secret-key-here"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# Recordatorios por email (Resend). Sin esta key, el cron corre pero no envía.
RESEND_API_KEY=
REMINDER_FROM="Turnero <onboarding@resend.dev>"

PAYMENT_PROVIDER=simulated
DEPOSIT_AMOUNT=2500
DEPOSIT_CURRENCY=ARS

# WhatsApp / Evolution API. mode=simulated no envia (demo); mode=live pega a Evolution.
WHATSAPP_MODE=simulated
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Analítica: fecha de "lanzamiento del sistema" (corte antes/después en el dashboard).
ANALYTICS_LAUNCH_DATE=2026-05-01

DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
JWT_SECRET="your-super-secret-key-here"
JWT_EXPIRES_IN="7d"
PORT=3000
NODE_ENV=development
# En producción CORS_ORIGIN es OBLIGATORIO y JWT_SECRET debe tener >= 32 caracteres.
CORS_ORIGIN=http://localhost:5173

# Nº de proxies de confianza para la IP real (Railway = 1). Para rate limiting.
TRUST_PROXY=1

# Gestión pública de reservas (F0). La consulta de turnos por email queda
# deshabilitada por defecto (exponía datos sin verificar); se re-habilita con OTP
# en F1. Poner en 'true' sólo si se acepta el riesgo temporalmente.
PUBLIC_MY_TURNS_ENABLED=false
# Secreto dedicado opcional para el token de gestión interino (si no, usa JWT_SECRET).
# MANAGE_TOKEN_SECRET=
# TTL del token efímero para abrir el stream SSE (dedicado, single-purpose).
SSE_TOKEN_TTL=60s
# Rate limiting (valores por defecto si se omiten).
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=5
RATE_LIMIT_PUBLIC_WINDOW_MS=60000
RATE_LIMIT_PUBLIC_MAX=30

# Recordatorios por email (Resend). Sin esta key, el cron corre pero no envía.
RESEND_API_KEY=
REMINDER_FROM="Turnero <onboarding@resend.dev>"

PAYMENT_PROVIDER=simulated
DEPOSIT_AMOUNT=2500
DEPOSIT_CURRENCY=ARS

# WhatsApp / Evolution API. mode=simulated no envia (demo); mode=live pega a Evolution.
WHATSAPP_MODE=simulated
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Analítica: fecha de "lanzamiento del sistema" (corte antes/después en el dashboard).
ANALYTICS_LAUNCH_DATE=2026-05-01
